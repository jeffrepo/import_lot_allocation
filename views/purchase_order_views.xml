<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_purchase_order_form_import_lot" model="ir.ui.view">
        <field name="name">purchase.order.form.import.lot</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_import_lots" type="object" class="oe_stat_button" icon="fa-tags">
                    <field name="import_lot_count" widget="statinfo" string="Import Lots"/>
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_import_lot" type="object" string="Create Import Lot" class="btn-secondary" attrs="{'invisible': [('state', 'not in', ('purchase', 'done'))]}"/>
            </xpath>
        </field>
    </record>
</odoo>
