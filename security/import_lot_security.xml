<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_rework" model="ir.module.category">
        <field name="name">Rework</field>
        <field name="description">Access rights for Rework and Import Lot operations.</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_rework_user" model="res.groups">
        <field name="name">Rework User</field>
        <field name="category_id" ref="module_category_rework"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_rework_manager" model="res.groups">
        <field name="name">Rework Manager</field>
        <field name="category_id" ref="module_category_rework"/>
        <field name="implied_ids" eval="[(4, ref('group_rework_user'))]"/>
    </record>
</odoo>
